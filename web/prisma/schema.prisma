generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Neon's Vercel integration prefixed its vars with DATABASE_URL_, so the
  // pooled connection is DATABASE_URL_DATABASE_URL and the direct (for
  // migrations / db push) is DATABASE_URL_UNPOOLED.
  url       = env("DATABASE_URL_DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  // comma-separated roles: USER,BUSINESS_OWNER,EVENT_ORGANIZER,ADMIN
  roles        String   @default("USER")
  createdAt    DateTime @default(now())

  businesses    Business[]
  reviews       Review[]
  favorites     Favorite[]
  follows       Follow[]
  events        Event[]
  claimRequests ClaimRequest[]
}

model Business {
  id                String    @id @default(cuid())
  name              String
  slug              String    @unique
  category          String
  description       String    @default("")
  address           String    @default("")
  city              String
  postcode          String    @default("")
  lat               Float?
  lng               Float?
  phone             String    @default("")
  website           String    @default("")
  email             String    @default("")
  socials           String    @default("{}") // JSON {instagram, facebook, tiktok}
  openingHours      String    @default("{}") // JSON {mon:[{open,close}],...}

  // --- pride / identity (Phase 1) ---
  coverImageUrl   String  @default("")
  founderName     String  @default("")
  founderPhotoUrl String  @default("")
  founderStory    String  @default("")
  brandStory      String  @default("")
  yearFounded     Int?
  signatureItems  String  @default("[]") // JSON [{title, description, imageUrl}]

  verificationLevel Int       @default(0) // 0-4
  featured          Boolean   @default(false)
  plan              String    @default("FREE") // FREE | VERIFIED | FEATURED
  status            String    @default("PENDING") // PENDING | APPROVED | REJECTED
  ownerId           String? // verified owner — only set on admin approval / paid claim
  submittedById     String? // creator of an owner-submitted listing (no owner benefits until approved)
  claimedAt         DateTime?
  createdAt         DateTime  @default(now())

  // --- source tracking (real-data upgrade) ---
  sourceType          String    @default("admin_created") // google_places | companies_house | openstreetmap | owner_submitted | admin_created | demo | facebook_page | instagram | community_referral | flyer | other
  sourceId            String    @default("")
  sourceUrl           String    @default("")
  lastSourceCheckedAt DateTime?
  dataConfidenceScore Int       @default(0) // 0-100, evidence-based
  googleRating        Float?
  googleReviewCount   Int?
  mapsUrl             String    @default("")
  companyNumber       String    @default("")

  // --- auto-approval (trust filter) ---
  verificationStatus String @default("") // "" | auto_verified
  approvedBy         String @default("") // "" | system | <adminId>
  approvalReason     String @default("")
  reviewBucket       String @default("") // "" | needs_enrichment

  owner           User?            @relation(fields: [ownerId], references: [id])
  photos          BusinessPhoto[]
  reviews         Review[]
  favorites       Favorite[]
  follows         Follow[]
  claimRequests   ClaimRequest[]
  analyticsEvents AnalyticsEvent[]
  sources         BusinessSource[]
  analyticsDaily  BusinessAnalyticsDaily[]
  prideEvents     PrideEvent[]
  reports         Report[]

  @@index([category, city, status])
  @@index([sourceType, status])
}

model BusinessSource {
  id         String   @id @default(cuid())
  businessId String
  sourceType String // google_places | companies_house | owner_submitted | admin_created | demo
  sourceId   String // place id, company number, submission id
  sourceUrl  String   @default("")
  rawData    String   @default("{}") // JSON snapshot from the source API
  fetchedAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId])
}

model BusinessPhoto {
  id         String @id @default(cuid())
  businessId String
  url        String
  alt        String @default("")
  sortOrder  Int    @default(0)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Review {
  id               String    @id @default(cuid())
  businessId       String
  userId           String
  rating           Int
  title            String    @default("")
  body             String
  status           String    @default("VISIBLE") // VISIBLE | REMOVED
  ownerResponse    String?
  ownerRespondedAt DateTime?
  createdAt        DateTime  @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
}

model Follow {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  type        String
  description String   @default("")
  imageUrl    String   @default("")
  startsAt    DateTime
  endsAt      DateTime?
  venueName   String   @default("")
  address     String   @default("")
  city        String
  lat         Float?
  lng         Float?
  ticketUrl   String   @default("")
  priceFrom   Float?
  organizerId String
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())

  // --- source tracking (real-data upgrade) ---
  sourceType String @default("admin_created") // owner_submitted | admin_created | demo
  sourceUrl  String @default("")

  organizer       User             @relation(fields: [organizerId], references: [id])
  analyticsEvents AnalyticsEvent[]
  sources         EventSource[]

  @@index([city, status, startsAt])
  @@index([sourceType, status])
}

model EventSource {
  id         String   @id @default(cuid())
  eventId    String
  sourceType String // owner_submitted | admin_created | demo
  sourceId   String   @default("")
  sourceUrl  String   @default("")
  createdAt  DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model BusinessAnalyticsDaily {
  id              String   @id @default(cuid())
  businessId      String
  date            String // YYYY-MM-DD (local)
  views           Int      @default(0)
  phoneClicks     Int      @default(0)
  websiteClicks   Int      @default(0)
  directionClicks Int      @default(0)
  shareClicks     Int      @default(0)
  bookingClicks   Int      @default(0)
  updatedAt       DateTime @default(now()) @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, date])
  @@index([businessId, date])
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  type       String // LISTING_VIEW | PHONE_CLICK | WEBSITE_CLICK | DIRECTION_CLICK | SHARE_CLICK | BOOKING_CLICK | EVENT_VIEW | TICKET_CLICK | SEARCH_IMPRESSION
  businessId String?
  eventId    String?
  createdAt  DateTime @default(now())

  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  event    Event?    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([type, businessId, createdAt])
  @@index([type, eventId, createdAt])
}

// --- Trust & safety: user reports / moderation queue ---
model Report {
  id            String    @id @default(cuid())
  businessId    String?
  reason        String // incorrect_info | duplicate | fake_review | inappropriate | impersonation | fraud | safety | other
  details       String    @default("")
  reporterId    String? // null = anonymous
  reporterEmail String    @default("")
  status        String    @default("open") // open | reviewing | resolved | dismissed
  createdAt     DateTime  @default(now())
  reviewedAt    DateTime?
  reviewedBy    String?

  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([businessId])
}

// --- Pride measurement layer (North-Star: Share Rate) ---
// Canonical, richly-attributed event stream for the "pride loop". Single source
// of truth for the Share Rate KPI (claimed businesses with >=1 distribution
// share / total claimed) and all owner/admin pride analytics. Context fields
// (city/category/trustScore/completionScore/ownerUserId) are resolved
// server-side at write time so reads are pure aggregation with no extra joins.
model PrideEvent {
  id              String   @id @default(cuid())
  action          String // CLAIM_APPROVED | PROFILE_VIEW | SHARE_KIT_OPENED | SHARE_IMAGE_GENERATED | SHARE_DOWNLOAD | SHARE_COPY_LINK | SHARE_WHATSAPP | SHARE_INSTAGRAM | SHARE_QR_SCAN | CONTACT_CLICK | WEBSITE_CLICK | DIRECTIONS_CLICK
  businessId      String?
  ownerUserId     String? // business owner at write time (nullable until claimed)
  visitorId       String   @default("") // anonymous first-party UUID; "system" for server events
  channel         String   @default("") // whatsapp | instagram | qr | copy_link | download | web_share | direct
  asset           String   @default("") // card | story | poster | ""
  city            String   @default("")
  category        String   @default("")
  trustScore      Int      @default(0)
  completionScore Int      @default(0)
  referrer        String   @default("")
  utmSource       String   @default("")
  utmMedium       String   @default("")
  utmCampaign     String   @default("")
  dedupeKey       String?  @unique // idempotency: retried/duplicate events collapse
  createdAt       DateTime @default(now())

  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([action, createdAt])
  @@index([businessId, action])
  @@index([businessId, visitorId])
  @@index([createdAt])
}

model Ad {
  id        String    @id @default(cuid())
  placement String // HOME_HERO | SEARCH_RESULTS | BUSINESS_DETAIL | EVENT_DETAIL
  imageUrl  String    @default("")
  headline  String
  body      String    @default("")
  targetUrl String
  active    Boolean   @default(true)
  startsAt  DateTime  @default(now())
  endsAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([placement, active])
}

model ProcessedStripeEvent {
  id        String   @id // Stripe event id (evt_...)
  type      String
  createdAt DateTime @default(now())
}

model ImportJob {
  id         String    @id @default(cuid())
  type       String // google_places | companies_house | openstreetmap
  query      String
  status     String    @default("running") // running | completed | failed
  found      Int       @default(0)
  imported   Int       @default(0)
  duplicates Int       @default(0)
  skipped    Int       @default(0)
  durationMs Int?
  errors     String    @default("") // raw error log
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
}

model ClaimRequest {
  id            String    @id @default(cuid())
  businessId    String
  userId        String
  claimantName  String    @default("")
  claimantEmail String    @default("")
  claimantPhone String    @default("")
  founderName   String    @default("")
  founderStory  String    @default("")
  evidenceUrl   String    @default("")
  notes         String    @default("")
  status        String    @default("pending") // pending | approved | rejected | needs_more_evidence
  paymentStatus String    @default("pending_payment") // pending_payment | paid (Stripe later)
  reviewedAt    DateTime?
  reviewedBy    String? // admin user id
  createdAt     DateTime  @default(now())
  // legacy OTP columns (unused; kept to avoid a destructive migration)
  method        String?
  code          String?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

// --- Monetisation (future-ready; NOT wired to Stripe yet) ---
// Amounts are integer pence; currency defaults to GBP. stripe* columns are
// nullable and present now so Stripe Milestone B needs no further migration.

model Subscription {
  id                   String    @id @default(cuid())
  businessId           String?
  userId               String?
  planType             String // VERIFIED | FEATURED | AI_TOOLKIT
  status               String    @default("pending") // pending | active | past_due | cancelled
  amount               Int       @default(0) // monthly price in pence
  currency             String    @default("gbp")
  interval             String    @default("month") // month | year
  paymentStatus        String    @default("pending") // pending | paid | failed | refunded | cancelled
  startDate            DateTime?
  endDate              DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @default(now()) @updatedAt

  @@index([status, planType])
  @@index([businessId])
}

model Payment {
  id                    String    @id @default(cuid())
  businessId            String?
  userId                String?
  kind                  String // subscription | claim | event_promotion | ad | ai_toolkit
  planType              String    @default("")
  status                String    @default("pending") // pending | paid | failed | refunded | cancelled
  amount                Int       @default(0) // in pence
  currency              String    @default("gbp")
  startDate             DateTime?
  endDate               DateTime?
  stripePaymentIntentId String?
  stripeChargeId        String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now()) @updatedAt

  @@index([kind, status])
  @@index([businessId])
}

model FeaturedSubscription {
  id            String    @id @default(cuid())
  businessId    String?
  userId        String?
  planType      String    @default("FEATURED")
  status        String    @default("pending") // pending | active | cancelled
  amount        Int       @default(0)
  currency      String    @default("gbp")
  placement     String    @default("") // optional priority placement key
  paymentStatus String    @default("pending") // pending | paid | failed | refunded | cancelled
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  @@index([status])
  @@index([businessId])
}

model EventPromotion {
  id            String    @id @default(cuid())
  eventId       String?
  businessId    String?
  userId        String?
  planType      String    @default("")
  package       String    @default("BRONZE") // BRONZE | SILVER | GOLD
  status        String    @default("pending") // pending | active | expired | cancelled
  amount        Int       @default(0)
  currency      String    @default("gbp")
  paymentStatus String    @default("pending") // pending | paid | failed | refunded | cancelled
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  @@index([status])
  @@index([eventId])
}

model AdCampaign {
  id            String    @id @default(cuid())
  businessId    String?
  userId        String?
  planType      String    @default("")
  placement     String    @default("") // HOME_HERO | SEARCH_RESULTS | BUSINESS_DETAIL | EVENT_DETAIL
  status        String    @default("pending") // pending | active | paused | ended
  amount        Int       @default(0)
  currency      String    @default("gbp")
  paymentStatus String    @default("pending") // pending | paid | failed | refunded | cancelled
  impressions   Int       @default(0)
  clicks        Int       @default(0)
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  @@index([status, placement])
  @@index([businessId])
}

model AiToolkitSubscription {
  id            String    @id @default(cuid())
  businessId    String?
  userId        String?
  planType      String    @default("AI_TOOLKIT")
  status        String    @default("pending") // pending | active | cancelled
  amount        Int       @default(0)
  currency      String    @default("gbp")
  paymentStatus String    @default("pending") // pending | paid | failed | refunded | cancelled
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  @@index([status])
  @@index([businessId])
}
