generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  // comma-separated roles: USER,BUSINESS_OWNER,EVENT_ORGANIZER,ADMIN
  roles        String   @default("USER")
  createdAt    DateTime @default(now())

  businesses    Business[]
  reviews       Review[]
  favorites     Favorite[]
  follows       Follow[]
  events        Event[]
  claimRequests ClaimRequest[]
}

model Business {
  id                String    @id @default(cuid())
  name              String
  slug              String    @unique
  category          String
  description       String    @default("")
  address           String    @default("")
  city              String
  postcode          String    @default("")
  lat               Float?
  lng               Float?
  phone             String    @default("")
  website           String    @default("")
  socials           String    @default("{}") // JSON {instagram, facebook, tiktok}
  openingHours      String    @default("{}") // JSON {mon:[{open,close}],...}
  verificationLevel Int       @default(0) // 0-4
  featured          Boolean   @default(false)
  plan              String    @default("FREE") // FREE | VERIFIED | FEATURED
  status            String    @default("PENDING") // PENDING | APPROVED | REJECTED
  ownerId           String?
  claimedAt         DateTime?
  createdAt         DateTime  @default(now())

  // --- source tracking (real-data upgrade) ---
  sourceType          String    @default("admin_created") // google_places | companies_house | owner_submitted | admin_created | demo
  sourceId            String    @default("")
  sourceUrl           String    @default("")
  lastSourceCheckedAt DateTime?
  dataConfidenceScore Int       @default(0) // 0-100, evidence-based
  googleRating        Float?
  googleReviewCount   Int?
  mapsUrl             String    @default("")
  companyNumber       String    @default("")

  owner           User?            @relation(fields: [ownerId], references: [id])
  photos          BusinessPhoto[]
  reviews         Review[]
  favorites       Favorite[]
  follows         Follow[]
  claimRequests   ClaimRequest[]
  analyticsEvents AnalyticsEvent[]
  sources         BusinessSource[]

  @@index([category, city, status])
  @@index([sourceType, status])
}

model BusinessSource {
  id         String   @id @default(cuid())
  businessId String
  sourceType String // google_places | companies_house | owner_submitted | admin_created | demo
  sourceId   String // place id, company number, submission id
  sourceUrl  String   @default("")
  rawData    String   @default("{}") // JSON snapshot from the source API
  fetchedAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId])
}

model BusinessPhoto {
  id         String @id @default(cuid())
  businessId String
  url        String
  alt        String @default("")
  sortOrder  Int    @default(0)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Review {
  id               String    @id @default(cuid())
  businessId       String
  userId           String
  rating           Int
  title            String    @default("")
  body             String
  status           String    @default("VISIBLE") // VISIBLE | REMOVED
  ownerResponse    String?
  ownerRespondedAt DateTime?
  createdAt        DateTime  @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
}

model Follow {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  type        String
  description String   @default("")
  imageUrl    String   @default("")
  startsAt    DateTime
  endsAt      DateTime?
  venueName   String   @default("")
  address     String   @default("")
  city        String
  lat         Float?
  lng         Float?
  ticketUrl   String   @default("")
  priceFrom   Float?
  organizerId String
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())

  // --- source tracking (real-data upgrade) ---
  sourceType String @default("admin_created") // owner_submitted | admin_created | demo
  sourceUrl  String @default("")

  organizer       User             @relation(fields: [organizerId], references: [id])
  analyticsEvents AnalyticsEvent[]
  sources         EventSource[]

  @@index([city, status, startsAt])
  @@index([sourceType, status])
}

model EventSource {
  id         String   @id @default(cuid())
  eventId    String
  sourceType String // owner_submitted | admin_created | demo
  sourceId   String   @default("")
  sourceUrl  String   @default("")
  createdAt  DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model ImportJob {
  id         String    @id @default(cuid())
  type       String // google_places | companies_house
  query      String
  status     String    @default("running") // running | completed | failed
  found      Int       @default(0)
  imported   Int       @default(0)
  duplicates Int       @default(0)
  errors     String    @default("")
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
}

model ClaimRequest {
  id         String   @id @default(cuid())
  businessId String
  userId     String
  method     String // EMAIL | PHONE
  code       String
  status     String   @default("PENDING") // PENDING | VERIFIED | REJECTED
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  type       String // LISTING_VIEW | PHONE_CLICK | WEBSITE_CLICK | EVENT_VIEW | TICKET_CLICK | SEARCH_IMPRESSION
  businessId String?
  eventId    String?
  createdAt  DateTime @default(now())

  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  event    Event?    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([type, businessId, createdAt])
  @@index([type, eventId, createdAt])
}

model Ad {
  id        String   @id @default(cuid())
  placement String // HOME_HERO | SEARCH_RESULTS | BUSINESS_DETAIL | EVENT_DETAIL
  imageUrl  String   @default("")
  headline  String
  body      String   @default("")
  targetUrl String
  active    Boolean  @default(true)
  startsAt  DateTime @default(now())
  endsAt    DateTime?
  createdAt DateTime @default(now())

  @@index([placement, active])
}
